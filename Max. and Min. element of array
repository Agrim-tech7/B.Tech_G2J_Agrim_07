#include<stdio.h>
int main()
{
int a[50],n,i,max,min;
printf("enter number of elements=\t");
scanf("%d",&n);
for (i=0;i<n;i++)
{
printf("enter a[%d]=",i);
scanf("%d",&a[i]);
}
max=a[0];
min=a[0];
for (i=1;i<n;i++)
{ 
if (a[i]>max)
{
    max=a[i];
}
if (a[i]<min)
{
    min=a[i];
}
}
printf("maximum value=%d\n",max);
printf("minimum value=%d",min);
return 0;
}
